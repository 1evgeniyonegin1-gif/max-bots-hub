# ====================
# DATABASE
# ====================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/max_bots_hub

# ====================
# APP
# ====================
DEBUG=false
APP_NAME=MAX BOTS HUB
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000

# ====================
# SECURITY
# ====================
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ====================
# ADMIN
# ====================
ADMIN_TELEGRAM_IDS=123456789,987654321

# ====================
# AI PROVIDERS
# ====================

# Claude (основной для диалогов)
ANTHROPIC_API_KEY=sk-ant-api03-xxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096

# Deepseek (для контента - дешевле)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# YandexGPT (резервный)
YANDEX_SERVICE_ACCOUNT_ID=aje76dc7i20078podfrc
YANDEX_KEY_ID=ajensd96tl0d2q9fqmp9
YANDEX_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
YANDEX_FOLDER_ID=b1gibb3gjf11pjbu65r3
YANDEX_MODEL=yandexgpt-32k

# ====================
# TELEGRAM (админ-бот для уведомлений)
# ====================
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ====================
# MAX MESSENGER
# ====================
MAX_API_URL=https://api.max.team
MAX_MASTER_BOT_TOKEN=your_master_bot_token_from_@MasterBot

# ====================
# PAYMENTS (СБП)
# ====================
SBP_ENABLED=false
SBP_MERCHANT_ID=your_merchant_id
SBP_SECRET_KEY=your_secret_key

# ====================
# REDIS (кеширование)
# ====================
REDIS_URL=redis://localhost:6379/0

# ====================
# FILE STORAGE
# ====================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ====================
# CORS
# ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ====================
# RATE LIMITING
# ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
